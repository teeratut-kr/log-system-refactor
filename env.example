# Backend
APP_TITLE=Unified Log Ingestion API
APP_ENV=development
LOG_LEVEL=INFO
LOG_USE_JSON=false
SYSLOG_UDP_HOST=0.0.0.0
SYSLOG_UDP_PORT=5514
RETENTION_DAYS=7
RETENTION_CLEANUP_INTERVAL_MINUTES=60
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logs_db

# Frontend
API_BASE_URL=http://127.0.0.1:8012
DASHBOARD_API_BASE_URL=http://127.0.0.1:8012
DASHBOARD_REQUEST_TIMEOUT_SECONDS=15
DASHBOARD_DEFAULT_FETCH_LIMIT=1000
DASHBOARD_DEFAULT_LOOKBACK_DAYS=7
DASHBOARD_SEVERITY_THRESHOLD_HIGH=5
DASHBOARD_RAW_PREVIEW_MAX_LEN=72
